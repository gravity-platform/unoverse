{
  "name": "@gravity-platform/unoverse-core",
  "version": "0.0.2",
  "description": "Unoverse core SDK — framework-agnostic MCP client + merge-state store (the channel brain)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
