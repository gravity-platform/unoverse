    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsup && node --test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
